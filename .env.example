# Copy to `.env` for a fresh clone (the template repo uses a gitignored `.env` with these values).
# Start Mongo: Docker Desktop running, then `docker compose up -d mongodb`

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=vitalshelf

# MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority
